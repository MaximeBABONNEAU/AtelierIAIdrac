{
  "_comment": "AI Marketing Academy — Regles Firebase RTDB v2 (Auth anonyme + propriete par compte). SOURCE ANNOTEE. Deploy CLI : 'firebase deploy --only database' utilise database.rules.json (genere depuis ce fichier : node -e \"const o=require('./firebase-rules.json');require('fs').writeFileSync('database.rules.json',JSON.stringify({rules:o.rules},null,2))\"). Sinon coller la cle 'rules' dans Console > Realtime Database > Rules > Publier.",
  "_security_notes": [
    "L'app se connecte en anonyme (firebase.auth().signInAnonymously) : chaque appareil obtient un uid.",
    "A la 1ere connexion d'un compte, /owners/{key} est fixe a l'uid. Ensuite, seul cet uid peut ecrire l'etat/le resume de ce compte -> un etudiant ne peut pas falsifier les donnees d'un autre.",
    "Les mots de passe sont haches en SHA-256 sale par compte cote client ; /accounts n'est lisible que par un utilisateur authentifie.",
    "L'auth anonyme ne distingue pas admin/etudiant : le gate admin reste cote client (mot de passe SHA-256 fort). /config et annonces sont donc ecrivables par tout utilisateur authentifie (acceptable en atelier encadre).",
    "Pour deverrouiller la propriete (ex: changement d'appareil), le formateur peut supprimer /owners/{key} depuis la console.",
    "Anti-triche points : les gains XP (states/students) sont plafonnes a +500 par ecriture et ne peuvent etre negatifs ; les points PvP ne peuvent pas baisser et augmentent de +300 max par ecriture ; wins/losses +2 max. Bloque l'inflation grossiere des scores via la console."
  ],
  "rules": {
    ".read": false,
    ".write": false,

    "config": {
      ".read": true,
      ".write": "auth != null"
    },

    "owners": {
      ".read": true,
      "$key": {
        ".write": "(!data.exists() || data.val() === auth.uid) && auth != null",
        ".validate": "newData.isString() || !newData.exists()"
      }
    },

    "accounts": {
      ".read": true,
      "$accountKey": {
        ".write": "auth != null && (newData.exists() && newData.hasChildren(['firstName', 'lastName', 'passwordHash', 'createdAt']) || !newData.exists())",
        ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)",
        "firstName":  { ".validate": "newData.isString() && newData.val().length < 60" },
        "lastName":   { ".validate": "newData.isString() && newData.val().length < 60" },
        "passwordHash": { ".validate": "newData.isString() && newData.val().length < 200" },
        "createdAt":  { ".validate": "newData.isString() && newData.val().length < 40" },
        "lastLogin":  { ".validate": "newData.isString() || newData.val() == null" }
      }
    },

    "states": {
      ".read": true,
      "$accountKey": {
        ".write": "auth != null && (!root.child('owners/' + $accountKey).exists() || root.child('owners/' + $accountKey).val() === auth.uid)",
        ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)",
        "xp": {
          "total": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000 && (!data.exists() || newData.val() <= data.val() + 500)" }
        }
      }
    },

    "students": {
      ".read": true,
      "$accountKey": {
        ".write": "auth != null && (!root.child('owners/' + $accountKey).exists() || root.child('owners/' + $accountKey).val() === auth.uid)",
        ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)",
        "name":  { ".validate": "newData.isString() && newData.val().length < 80" },
        "xp":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000 && (!data.exists() || newData.val() <= data.val() + 500)" },
        "online":{ ".validate": "newData.isBoolean()" }
      }
    },

    "submissions": {
      ".read": true,
      "$activityId": {
        "$accountKey": {
          ".write": "auth != null",
          ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/) && newData.exists()"
        }
      }
    },

    "pvp": {
      ".read": true,
      "$accountKey": {
        ".write": "auth != null && (!root.child('owners/' + $accountKey).exists() || root.child('owners/' + $accountKey).val() === auth.uid)",
        ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)",
        "points":         { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 300))" },
        "wins":           { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 2))" },
        "losses":         { ".validate": "newData.isNumber() && newData.val() >= 0 && (!data.exists() || (newData.val() >= data.val() && newData.val() <= data.val() + 2))" },
        "battlesToday":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "lastBattleDate": { ".validate": "newData.isString() && newData.val().length < 40" }
      }
    },

    "votes": {
      ".read": true,
      "$voterKey": {
        ".write": "auth != null && (!root.child('owners/' + $voterKey).exists() || root.child('owners/' + $voterKey).val() === auth.uid)",
        ".validate": "$voterKey.matches(/^[a-z0-9_]{3,80}$/)",
        "$targetKey": {
          ".validate": "$targetKey.matches(/^[a-z0-9_]{3,80}$/) && (newData.val() === true || !newData.exists())"
        }
      }
    },

    "highlight_scores": {
      ".read": true,
      "$highlightId": {
        "$accountKey": {
          ".write": "auth != null && (!root.child('owners/' + $accountKey).exists() || root.child('owners/' + $accountKey).val() === auth.uid)",
          ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)"
        }
      }
    },

    "boss_scores": {
      ".read": true,
      "$bossId": {
        "$accountKey": {
          ".write": "auth != null && (!root.child('owners/' + $accountKey).exists() || root.child('owners/' + $accountKey).val() === auth.uid)",
          ".validate": "$accountKey.matches(/^[a-z0-9_]{3,80}$/)"
        }
      }
    },

    "reviews": {
      ".read": true,
      "$reviewerKey": {
        ".write": "auth != null && (!root.child('owners/' + $reviewerKey).exists() || root.child('owners/' + $reviewerKey).val() === auth.uid)"
      }
    },

    "activity_feed": {
      ".read": true,
      ".write": "auth != null"
    },

    "announcements": {
      ".read": true,
      ".write": "auth != null"
    },

    "inbox": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "dayLocks": {
      ".read": true,
      ".write": "auth != null"
    },

    "notifications": {
      ".read": true,
      ".write": "auth != null"
    },

    "chat": {
      ".read": "auth != null",
      "$msgId": {
        ".write": "auth != null && (!newData.exists() || newData.child('key').val() === '__formateur' || (root.child('accounts/' + newData.child('key').val()).exists() && root.child('owners/' + newData.child('key').val()).val() === auth.uid))",
        ".validate": "newData.hasChildren(['text', 'ts', 'key']) && newData.child('text').isString() && newData.child('text').val().length < 600"
      }
    },

    "feedback": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && (newData.exists() ? (root.child('accounts/' + newData.child('key').val()).exists() && root.child('owners/' + newData.child('key').val()).val() === auth.uid) : (data.exists() && root.child('owners/' + data.child('key').val()).val() === auth.uid))",
        ".validate": "newData.hasChildren(['key', 'ts'])",
        "status": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length < 20"
        },
        "votes": {
          "$voter": {
            ".write": "auth != null && root.child('accounts/' + $voter).exists() && root.child('owners/' + $voter).val() === auth.uid",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        }
      }
    },

    "duel_queue": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null && root.child('accounts/' + $key).exists() && (!root.child('owners/' + $key).exists() || root.child('owners/' + $key).val() === auth.uid)"
      }
    },

    "duels": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "duel_notify": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "livebattle": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "livebattle_content": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null && root.child('accounts/' + $key).exists() && (!root.child('owners/' + $key).exists() || root.child('owners/' + $key).val() === auth.uid)",
        ".validate": "$key.matches(/^[a-z0-9_]{3,80}$/) && (!newData.exists() || newData.hasChildren(['type', 'name']))"
      }
    },

    "avatarforge": {
      "requests": {
        ".read": "auth != null",
        "$key": {
          ".write": "auth != null && root.child('accounts/' + $key).exists() && (!root.child('owners/' + $key).exists() || root.child('owners/' + $key).val() === auth.uid)",
          ".validate": "$key.matches(/^[a-z0-9_]{3,80}$/) && (!newData.exists() || (newData.hasChildren(['prompt', 'slogan', 'ts']) && newData.child('prompt').isString() && newData.child('prompt').val().length < 600 && newData.child('slogan').isString() && newData.child('slogan').val().length < 300))"
        }
      },
      "jobs": {
        ".read": "auth != null",
        "$key": {
          ".write": "auth != null",
          ".validate": "$key.matches(/^[a-z0-9_]{3,80}$/)"
        }
      },
      "worker": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "promptmon": {
      "roster": {
        ".read": "auth != null",
        "$key": {
          ".write": "auth != null && root.child('accounts/' + $key).exists() && (!root.child('owners/' + $key).exists() || root.child('owners/' + $key).val() === auth.uid)",
          ".validate": "$key.matches(/^[a-z0-9_]{3,80}$/) && (!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 25))"
        }
      },
      "briefs": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "submissions": {
        ".read": "auth != null",
        "$briefId": {
          "$key": {
            ".write": "auth != null && root.child('accounts/' + $key).exists() && (!root.child('owners/' + $key).exists() || root.child('owners/' + $key).val() === auth.uid)",
            ".validate": "$key.matches(/^[a-z0-9_]{3,80}$/)",
            "matched": {
              ".write": "auth != null"
            }
          }
        }
      },
      "matches": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
